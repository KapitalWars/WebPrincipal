<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Conqueco</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#8B5CF6",     // violet moderne
                        primaryDark: "#6D28D9",
                        bg: "#0B0B10"
                    }
                }
            }
        }
    </script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-gradient-to-b from-gray-50 to-purple-50 text-gray-800">
    <header class="sticky top-0 z-50 backdrop-blur-md bg-white/70 border-b border-purple-100 shadow-sm">

        <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

            <!-- Brand -->
            <a asp-area="" asp-controller="Home" asp-action="Index"
               class="text-2xl font-extrabold text-primary tracking-tight">
                Conqueco
            </a>

            <!-- Links -->
            <div class="hidden md:flex items-center gap-8">

                <a asp-area="" asp-controller="Home" asp-action="Index"
                   class="text-gray-700 hover:text-primary transition font-medium">
                    Home
                </a>

                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="text-gray-700 hover:text-primary transition font-medium">
                    Privacy
                </a>

            </div>

            <!-- Right -->
            <div class="flex items-center gap-4">

                <div class="text-sm">
                    <partial name="_LoginPartial" />
                </div>

                <button class="md:hidden p-2 rounded-lg bg-purple-100 text-primary">
                    ☰
                </button>

            </div>

        </nav>
    </header>
    <div>
        <main class="flex-grow flex items-center justify-center px-4 py-10">
            <div class="w-full max-w-7xl">
                <div class="bg-white/80 backdrop-blur-md shadow-lg rounded-2xl p-6 border border-purple-100">
                    @RenderBody()
                </div>
            </div>
        </main>
    </div>

    <footer class="mt-auto border-t border-purple-100 bg-white/60 backdrop-blur-md">

        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col md:flex-row items-center justify-between">

            <p class="text-sm text-gray-500">
                © 2026 - <span class="text-primary font-semibold">Conqueco</span>
            </p>

            <div class="flex gap-4 text-sm">
                <a asp-area="" asp-controller="Home" asp-action="Privacy"
                   class="text-gray-500 hover:text-primary transition">
                    Privacy
                </a>

                <a href="#"
                   class="text-gray-500 hover:text-primary transition">
                    Support
                </a>
            </div>

        </div>

    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
