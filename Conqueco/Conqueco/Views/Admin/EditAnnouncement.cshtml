@{
    ViewData["Title"] = "Edit Announcement";
    var id = ViewBag.Id;
}

<div class="max-w-3xl">

    <h1 class="text-2xl font-bold mb-6">
        Edit Announcement
    </h1>

    <div class="space-y-4">

        <input id="title"
               class="w-full px-4 py-3 border rounded-xl"
               placeholder="Title" />

        <textarea id="content"
                  class="w-full px-4 py-3 border rounded-xl"
                  rows="6"></textarea>

        <label class="flex items-center gap-2">
            <input type="checkbox" id="isPinned" />
            Pinned
        </label>

        <label class="flex items-center gap-2">
            <input type="checkbox" id="isPublished" />
            Published
        </label>

        <button onclick="updateAnnouncement()"
                class="bg-blue-600 text-white px-4 py-2 rounded-xl">
            Save
        </button>

        <button onclick="deleteAnnouncement()"
                class="bg-red-600 text-white px-4 py-2 rounded-xl">
            Delete
        </button>

    </div>

</div>

<script>

    const id = "@id";

    async function load(){

        const res = await fetch(`/api/announcement/${id}`);
        const a = await res.json();

        document.getElementById("title").value = a.title;
        document.getElementById("content").value = a.content;
        document.getElementById("isPinned").checked = a.isPinned;
        document.getElementById("isPublished").checked = a.isPublished;
    }

    async function updateAnnouncement(){

        await fetch(`/api/announcement/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                title: document.getElementById("title").value,
                content: document.getElementById("content").value,
                isPinned: document.getElementById("isPinned").checked,
                isPublished: document.getElementById("isPublished").checked
            })
        });

        window.location.href = "/Admin/Announcements";
    }

    async function deleteAnnouncement(){

        if(!confirm("Delete ?")) return;

        await fetch(`/api/announcement/${id}`, {
            method: "DELETE"
        });

        window.location.href = "/Admin/Announcements";
    }

    load();

</script>