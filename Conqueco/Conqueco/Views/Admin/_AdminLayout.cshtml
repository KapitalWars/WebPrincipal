@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#8B5CF6"
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-gray-50 flex min-h-screen">

    <!-- SIDEBAR -->
    <aside class="w-64 bg-white border-r border-gray-200 p-6">

        <h1 class="text-xl font-bold text-primary mb-8">
            Conqueco Admin
        </h1>

        <nav class="flex flex-col gap-2">

            <a href="/Admin/Index"
               class="px-3 py-2 rounded-lg hover:bg-purple-50">
                Dashboard
            </a>

            <a href="/Admin/Users"
               class="px-3 py-2 rounded-lg hover:bg-purple-50">
                Users
            </a>

            <a href="/Admin/Announcements"
               class="px-3 py-2 rounded-lg hover:bg-purple-50">
                Announcements
            </a>

        </nav>

    </aside>

    <!-- MAIN -->
    <main class="flex-1 p-8">

        @RenderBody()

    </main>

</body>
</html>