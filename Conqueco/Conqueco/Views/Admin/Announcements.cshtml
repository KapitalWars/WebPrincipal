@{
    ViewData["Title"] = "Announcements";
}

<div class="space-y-6">

    <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold">
            Announcements
        </h1>

        <a href="/Admin/CreateAnnouncement"
           class="px-4 py-2 bg-primary text-white rounded-xl">
            New Announcement
        </a>
    </div>

    <div id="announcementList"
         class="space-y-4">
    </div>

</div>

<script>

    async function loadAnnouncements(){

        const res = await fetch("/api/announcement");

        const data = await res.json();

        const container = document.getElementById("announcementList");

        container.innerHTML = "";

        data.forEach(a => {

            container.innerHTML += `
                <div class="bg-white rounded-xl shadow border p-5">

                    <div class="flex justify-between items-center">

                        <div>
                            <h2 class="font-bold text-xl">
                                ${a.title}
                                ${a.isPinned ? '📌' : ''}
                            </h2>

                            <p class="text-sm text-gray-500">
                                ${new Date(a.createdAt).toLocaleDateString()}
                            </p>
                        </div>

                        <div class="flex gap-2">

                            <a href="/Admin/EditAnnouncement/${a.id}"
                               class="px-3 py-2 bg-blue-500 text-white rounded-lg">
                                Edit
                            </a>

                            <button
                                onclick="deleteAnnouncement('${a.id}')"
                                class="px-3 py-2 bg-red-500 text-white rounded-lg">
                                Delete
                            </button>

                        </div>

                    </div>

                </div>
            `;
        });
    }

    async function deleteAnnouncement(id){

        if(!confirm("Delete announcement ?"))
            return;

        await fetch(`/api/announcement/${id}`, {
            method:"DELETE"
        });

        loadAnnouncements();
    }

    loadAnnouncements();

</script>