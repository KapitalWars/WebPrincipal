@{
    ViewData["Title"] = "Register";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-purple-50 to-white">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-purple-100 p-8">

        <h2 class="text-2xl font-bold text-center text-primary mb-6">
            Create account
        </h2>

        <div class="space-y-4">
            <input id="pseudo" placeholder="Pseudo"
                   class="w-full px-4 py-3 rounded-xl border" />

            <input id="email"
                   type="email"
                   placeholder="Email"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-purple-100 outline-none" />

            <input id="password"
                   type="password"
                   placeholder="Password"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-purple-100 outline-none" />

            <input type="file" id="avatar" accept="image/*"
                   class="w-full px-4 py-3 rounded-xl border" />

            <button onclick="register()"
                    class="w-full bg-primary text-white py-3 rounded-xl shadow-md hover:bg-primaryDark transition">
                Register
            </button>

        </div>

        <p class="text-sm text-center text-gray-500 mt-4">
            Already have an account?
            <a href="/Auth/Login" class="text-primary hover:underline">Login</a>
        </p>

    </div>
</div>

<script>
    async function register() {

        const file = document.getElementById("avatar").files[0];

        let avatarBase64 = null;
        if (file) {
            avatarBase64 = await toBase64(file);
        }

        const dto = {
            email: document.getElementById("email").value,
            password: document.getElementById("password").value,
            pseudo: document.getElementById("pseudo").value,
            avatarBase64: avatarBase64
        };

        await fetch("/api/auth/register", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(dto)
        });

        window.location.href = "/AuthPage/Login";
    }

    function toBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        });
    }
</script>